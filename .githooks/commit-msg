#!/bin/sh

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Merge 커밋은 검사 제외
if echo "$COMMIT_MSG" | grep -qE "^Merge "; then
  exit 0
fi

# Co-Authored-By 금지
if echo "$COMMIT_MSG" | grep -qi "Co-Authored-By:"; then
  echo "❌ 커밋 거부: 'Co-Authored-By:' 트레일러는 사용할 수 없습니다."
  exit 1
fi

# 형식 검사: type(scope): 설명 또는 type: 설명
VALID_TYPES="feat|fix|refactor|style|test|docs|chore"
PATTERN="^($VALID_TYPES)(\([^)]+\))?: .+"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo "❌ 커밋 메시지 형식이 올바르지 않습니다."
  echo ""
  echo "  올바른 형식: type(scope): 한국어 설명"
  echo "  예시:        feat(auth): Google OAuth 로그인 구현"
  echo ""
  echo "  허용 type: feat | fix | refactor | style | test | docs | chore"
  exit 1
fi

exit 0
